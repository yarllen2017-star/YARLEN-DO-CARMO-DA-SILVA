// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: people
// Document ID: auto-generated
// Fields:
//   - name: string (required, 1-100 chars)
//   - birthDate: string (optional, ISO date)
//   - whatsapp: string (required, 10-20 chars)
//   - story: string (optional, max 5000 chars)
//   - type: string (required, 'visitor' or 'member')
//   - createdAt: timestamp (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidPerson(data) {
      return data.keys().hasAll(['name', 'whatsapp', 'type', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.whatsapp is string && data.whatsapp.size() >= 1 && data.whatsapp.size() <= 30 &&
             data.type in ['visitor', 'member'] &&
             data.createdAt is timestamp &&
             (!('birthDate' in data) || data.birthDate is string) &&
             (!('story' in data) || (data.story is string && data.story.size() <= 5000));
    }

    match /people/{personId} {
      // Allow read and create for everyone
      // Note: We are allowing public access because anonymous authentication 
      // is restricted in the Firebase console and the user requested "no login".
      allow read: if true;
      allow create: if isValidPerson(request.resource.data);
      allow update, delete: if false;
    }
  }
}
